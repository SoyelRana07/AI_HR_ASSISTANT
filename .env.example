# Option 1: set a full SQLAlchemy URL
DATABASE_URL=postgresql://postgres:your_password@localhost:5434/hrdb

# Option 2: set individual parts
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5434
DB_NAME=hrdb

# MCP mode options: local or remote
MCP_MODE=local
MCP_SERVER_URL=http://127.0.0.1:8003
MCP_TIMEOUT_SECONDS=5
# Set to 1 to disable local fallback when MCP_MODE=remote
MCP_STRICT_REMOTE=0

# LLM settings
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_SECONDS=60

# Backend API URL for Streamlit frontend
BACKEND_CHAT_URL=http://localhost:8000/chat

# Router rules configuration
ROUTER_RULES_PATH=llm/routing_rules.json
